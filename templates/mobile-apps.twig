{% extends base %}

{% block javascripts %}
	{{ parent() }}
{% endblock %}

{% block extra_styles %}
	<style>
	.tbl {width:100%;table-layout: fixed;}
	.calc-row {border-bottom: 0.4em solid transparent;}
	.calc-container:not(:last-child) {border-right:0.4em solid transparent;}
	.calc-link {display: block;border: 0.15em solid #d4d4d4;padding:0.4em;position:relative;}
	.calc__img-container,.calc__text {display: table-cell;vertical-align: middle;}
	.calc__img {margin-right: 0.4em;display: block;}
	.calc__img--round {border-radius: 0.2em;}
	.calc__text--title {display:block;margin-bottom:1em;font-size:1.1em;}
	.calc__text--small {font-size:1em;}
	.calc__text--desc {font-size:0.9em;color: #666666;}
	{% if mobile %}
	.calc-row {border-bottom: 0;}
	.calc-container {display: block;border-right:0;width:100%;border-bottom: 0.4em solid transparent;}
	.calc-container--last {border-bottom: 0;}
	.calc__text--title {font-size: 1em;}
	{% else %}
	.calc-link:hover {border-color: {{ dark_color }};}
	{% endif %}
	</style>
{% endblock %}

{% block resp_horiz_mobile %}
    {% if show_ads %}
        <!-- (Responsive) Horizontal -->
        <ins class="adsbygoogle"
             style="display:block;margin:1em 0"
             data-ad-client="ca-pub-1461238060884369"
             data-ad-slot="{{ ad_id['resp_horiz'] }}"
             data-ad-format="horizontal"></ins>
        <script>
        (adsbygoogle = window.adsbygoogle || []).push({});
        </script>
    {% endif %}
{% endblock %}

