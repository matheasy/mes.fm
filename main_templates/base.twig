<!DOCTYPE html>
{% if br_view_comments %}
    <html lang="es">
{% else %}
    <html lang="en">
{% endif %}
    <head>
        {# {% block ad_block_script %}<script src="https://mes.fm/main_js/showads.js"></script>{% endblock %} #}
        {% if localhost %}
            {% if local_root == "home_page" %}
                <base href="/MES/twig/{{ local_root }}/" />
            {% else %}
                <base href="/MES/twig/calcs/{{ local_root }}/" />
            {% endif %}
        {% else %}
            <base href="{{ root_domain }}" />
        {% endif %}
        <link rel="icon" href="{{ root_domain }}img/favicon.ico?v=1.0" type="image/x-icon" />
        {% block canonical_tag %}<link rel="canonical" href="{{ url }}" />{% endblock %}

        {% if title %}
            <title>{{ title ~ ' | ' ~ calc_name }}</title>
        {% else %}
            {% if local_root == "home_page" %}
                    <title>Math Easy Solutions</title>
                {% else %}
                    <title>{{ calc_name }} | Math Easy Solutions</title>
            {% endif %}
        {% endif %}

        <meta name="viewport" content="width=device-width, initial-scale=1">

        {% block bootstrap %}{% endblock %}

        <style>
        {% include 'reset.css' %}
        .warning-message {font-size:1em;text-align:center;padding:0.5em;background-color:{{dark_color}};color:white;}
        .button {color:{{ dark_color }};border:0.125em solid {{ dark_color }};margin:0.7em 0;padding:0.5em 0.2em;text-align:center;-moz-user-select:none; -webkit-user-select:none; -ms-user-select:none; user-select:none; cursor:pointer;}
        .button--subscribe {line-height:1.2;}
        .button--share-calc {display: inline-block;padding-left: 1em;padding-right: 1em;margin-top: 0.5em;margin-bottom: 0.5em;}
        .italic {font-style:italic;}
        .bold {font-weight:700;}
        .list {list-style-type:disc;}
        .list__indent {line-height:1.2;margin-left:2em;margin-top:0.4em;margin-bottom:0.2em;font-size: 0.95em;}
        .time {font-style:italic;font-weight:100;color:#939393;}
        .small-text {font-size:0.9em;}
        .big-text {font-size:1.1em;}
        .link {color:{{ dark_color }}; font-weight:700;}
        .link--dark {color: blue; font-weight: 700;}
        .link--dark:hover {text-decoration: underline;}
        .basic-table {margin:1em auto;}
        .basic-table td, .basic-table th {border: 1px solid black; padding:0.5em 1em; text-align: center;}
        .basic-table th {background-color: #ededed}
        .basic-table--full {width:100%;}
        .sponsored-ad {text-align:right;display:block;font-size:0.7em;margin-bottom:0.3em;font-style:italic;}
        .box-border {border:0.1em solid {{ dark_color }}; padding:1em;margin-bottom: 1.2em;}
        .selected {background-color: {{ dark_color }};color:white;}
        .right-arrow {font-size:2em;vertical-align:middle;margin:0 0.2em;display:inline-block;color:{{dark_color}};}
        .share-calc-url {border: 2px solid black;font-size:0.9em;display:inline-block;width:15.5em;padding:0.45em 0.8em;font-weight:700;vertical-align:middle;color:{{dark_color}};background-color:{{light_color}};}
        .share-calc-url-container {margin-bottom: 0.5em;display: inline-block;}
        .scissors-icon {vertical-align:middle;cursor: pointer;}
        .hide {display:none;}
        .crypto-container {background-color: #5eaade; padding: 10px; border-radius: 5px;}
        .crypto-text {color: white; line-height: 1.4; padding: 5px;}

        {% if mobile %}{% include 'main_mobile.css' %}{% else %}{% include 'main.css' %}{% endif %}
        .adsense{
            display: block;
        }

        .adsense--mobile {
            /*min-height: 300px;*/
            /*background-color: red;*/
        }
        /*.adsense--loaded .adsense__loading { display: none; }*/
        /*.adsense:before     { display: none !important; }*/
        /*.adsense ins        { width: 100%; height: 100%; display: block; }*/

        .info-bar,.color-box,.navbar,.footer {background-color: {{ dark_color }};}
        .dropdown-symbol--dark {color:{{ dark_color }};}
        .button--active {background-color: {{ dark_color }};color:white;}
        .navbar__dropdown-container {color: #222222;background-color: {{ light_color }};}
        .header2--top {margin-top: 0.5em;}
        .basic-table td, .basic-table th {border: 1px solid black; padding:0.3em 0.5em; text-align: center;}

        {% if local_root == "home_page" %}
            {% if mobile %}
            .logo {height:auto;width:100%;max-height: 4em;max-width:17.375em;}
            .navbar-button {margin-left:1em;}
            .calculator-title {display: none;}
            {% else %}
            .logo {height:4em;width:17.375em;}
            .info-bar__logo-container {display: none;}
            {% endif %}
        {% endif %}

        </style>

        {% block extra_styles %}{% endblock %}

        {% if gplus_author %}
            <link rel="publisher" href="{{ gplus_author }}">
        {% endif %}

        <meta property="fb:app_id" content="{{ fb_id }}" />
        <meta name="author" content="{{ author_name|default(calc_name ~ ' Staff') }}">
        <meta property="og:type" content="{{ og_type|default('website') }}" />
        <meta property="og:url" content="{{ url }}" />
        {% if local_root == "home_page" %}
            <meta property="og:title" content="{{ page_title|default('Math Easy Solutions')}}" />
        {% else %}
            <meta property="og:title" content="{{ page_title|default(calc_name ~ ' | Math Easy Solutions') }}" />
        {% endif %}
        <meta property="og:image" content="{{ og_img_url|default(root_domain ~ 'img/logo-big.png') }}" />
        <meta property="og:description" content="{{ og_description }}" />

        <meta name="description" content="{{ og_description }}">

        {% if og_img_url %}
            <meta name="twitter:card" content="summary_large_image">
        {% else %}
            <meta name="twitter:card" content="summary">
        {% endif %}
        <meta name="twitter:site" content="@{{ social_medias.twitter }}">
        <meta name="twitter:title" content="{{ page_title|default(calc_name) }}">
        <meta name="twitter:description" content="{{ og_description }}">
        <meta name="twitter:image" content="{{ og_img_url|default(root_domain ~ 'img/logo-big.png') }}">
        <meta name="twitter:image:alt" content="{{ page_title|default(calc_name) }}">

        {% block rel_tags %}{% endblock %}

        {% if tag_manager %}
            <!-- Google Tag Manager -->
            <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
            new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
            j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
            'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
            })(window,document,'script','dataLayer','{{ tag_manager }}');</script>
            <!-- End Google Tag Manager -->
        {% endif %}

        {# {% if show_ads %}
            <!-- anchor ads -->
            <script>
              (adsbygoogle = window.adsbygoogle || []).push({
                google_ad_client: "ca-pub-1461238060884369",
                enable_page_level_ads: true
              });
            </script>
        {% endif %} #}

        {% block extra_head %}{% endblock %}

        {# {% if show_ads %}
            <script src="//pagead2.googlesyndication.com/pagead/js/adsbygoogle.js" async></script>
        {% endif %} #}

        {% if addtoany|default(1) %}
            <script type="text/javascript" src="//static.addtoany.com/menu/page.js" async></script>
        {% endif %}

        <!-- Google Analytics -->
        <script>
          (function(i,s,o,g,r,a,m){i['GoogleAnalyticsObject']=r;i[r]=i[r]||function(){
          (i[r].q=i[r].q||[]).push(arguments)},i[r].l=1*new Date();a=s.createElement(o),
          m=s.getElementsByTagName(o)[0];a.async=1;a.src=g;m.parentNode.insertBefore(a,m)
          })(window,document,'script','//www.google-analytics.com/analytics.js','ga');

          ga('create', '{{ ga_id }}', '{{ url_short }}');
          ga('require', 'displayfeatures');
          ga('send', 'pageview');
        </script>
    </head>
    <body>
        {# {% block ad_block_message %}
            <p id="warning-message" class="warning-message hide">We notice that you are using AdBlock. Please whitelist {{ calc_name }} to help keep this site up and running! :)</p>
            <script>if(window.areAdsShowing === undefined){document.getElementById("warning-message").classList.remove("hide");}</script>
        {% endblock %} #}
        {% if tag_manager %}
            <!-- Google Tag Manager (noscript) -->
            <noscript><iframe src="https://www.googletagmanager.com/ns.html?id={{ tag_manager }}"
            height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
            <!-- End Google Tag Manager (noscript) -->
        {% endif %}
        <div id="outer-container" class="outer-container">
            {% block main_container %}
                <div class = "inner-container">
                    {% block header %}
                        <div id="header" class="header">
                            {% block logo_container %}
                                <a class="logo-image-container" href='{{ root_domain }}'><img height="88" width="88" id="logo" class="logo lazyload" alt="{{ calc_name }} logo" data-src="{{ root_domain }}img/logo.png"></a>
                            {% endblock %}

                            <div class="logo-text-container">
                                <a class="calculator-title-link" href='{{ root_domain }}'>
                                    <p class="calculator-title">{{ calc_name }} by MES</p>
                                </a>
                                <p class="tag-line">{{ tag_line }}</p>
                                {# {% block search_bar %}
                                    {% if not hide_search %}
                                        <form action="search-results" id="cse-search-box">
                                          <div style="margin-top:0.5em">
                                            <input type="hidden" name="cx" value="partner-pub-1461238060884369:3982767264" />
                                            <input type="hidden" name="cof" value="FORID:10" />
                                            <input type="hidden" name="ie" value="UTF-8" />
                                            <input type="text" name="q" size="25" />
                                            <input type="submit" name="sa" value="Search" />
                                          </div>
                                        </form>
                                    {% endif %}
                                {% endblock %} #}
                            </div>

                            <div class="social-container">
                                {% if social_medias %}<p class="social__text">Follow us!</p>{% endif %}
                                {% block social %}{% include 'social.twig' %}{% endblock %}
                            </div>

                            {% block app_store_badges %}
                                <div class="social-container--bottom">
                                    {% if app_store_link %}<a target="_blank" href='{{ app_store_link }}'><img height="40" alt='Get it on the App Store' data-src='//mes.fm/main_img/app-store-badge.png' class="lazyload" /></a>{% endif %}
                                    {% if google_play_link %}<a target="_blank" href='{{ google_play_link }}' style="margin-left:0.40em;"><img height="40" alt='Get it on Google Play' data-src='//mes.fm/main_img/google-play-badge.png' class="lazyload"/></a>{% endif %}
                                </div>
                            {% endblock %}
                        </div>
                        <div class="info-bar-container">
                            <ul id="info-bar" class="info-bar shadow">
                                <li class="info-bar__item"><a class="info-bar__item__text" href='{{ root_domain }}'>Home</a></li>

                                {% for item in navbar|slice(0,7) %}
                                    <li class="info-bar__item"><a target="{{ item.link_window | default('_self') }}" class="info-bar__item__text" href='{{ item.url }}'>{{ item.label }}</a></li>
                                {% endfor %}

                                {% if local_root == "home_page" %}
                                    <li class="info-bar__item"><a class="info-bar__item__text" href='{{ root_domain }}calculators'>Calculators</a></li>
                                    <li class="info-bar__item"><a class="info-bar__item__text" href='{{ root_domain }}tools'>Tools</a></li>
                                    <li class="info-bar__item"><a class="info-bar__item__text" href='{{ root_domain }}mobile-apps'>Mobile Apps</a></li>
                                    <li class="info-bar__item"><a class="info-bar__item__text" href='{{ root_domain }}partners'>Partners</a></li>
                                    <li class="info-bar__item"><a class="info-bar__item__text" target='_blank' href='https://teespring.com/stores/mes-store'>Store</a></li>
                                {% endif %}
                                {% if navbar | length < 5 %}
                                    <li class="info-bar__item"><a class="info-bar__item__text" href='{{ root_domain }}contact'>Contact Us</a></li>
                                    <li class="info-bar__item"><a class="info-bar__item__text" target='_blank' href='https://mes.fm/donate'>Donate</a></li>
                                {% endif %}
                            </ul>
                        </div>
                        <a class="info-bar__logo-container" href="https://mes.fm" title="Math Easy Solutions"><img id="mes-logo" class="info-bar__logo lazyload" alt="math easy solutions logo" height="29" width="126" data-src="//mes.fm/main_img/mes-logo-small.png"></a>
                    {% endblock %}
                    {% block body %}
                        {% block resp_horiz %}
                            {% if show_ads and ad_id['resp_horiz'] %}
                                <!-- (Responsive) Horizontal -->
                                <div class="adsense" style="height:280px">
                                    <ins class="adsbygoogle"
                                     style="display:block;margin:0.8em -1em 0 -1em;"
                                     data-ad-client="ca-pub-1461238060884369"
                                     data-ad-slot="{{ ad_id['resp_horiz'] }}"
                                     data-ad-format="auto"
                                     data-full-width-responsive="true"></ins>
                                </div>
                                {# <script>
                                (adsbygoogle = window.adsbygoogle || []).push({});
                                </script> #}
                            {% endif %}
                        {% endblock %}
                        <div class="outer-page-content">
                            <div class="page-content">
                                {% block calc_info %}
                                    <div class="color-box"></div>
                                    <h1 class="page-title">{% block page_title %}{{ page_title|default(calc_name) }}{% endblock %}</h1>
                                    {% if page_description %}
                                        <p class="page-description">{{ page_description|raw }}</p>
                                    {% endif %}
                                {% endblock %}

                                {% if addtoany|default(1) %}
                                    <div class="addtoany-container">
                                        <span class="social__text">Share:</span>
                                        <!-- AddToAny BEGIN -->
                                        <div class="a2a_kit a2a_kit_size_32 a2a_default_style">
                                        <a class="addtoany__button a2a_button_facebook"></a>
                                        <a class="addtoany__button a2a_button_twitter"></a>
                                        <a class="addtoany__button a2a_button_pinterest"></a>
                                        <a class="addtoany__button a2a_button_whatsapp"></a>
                                        <a class="addtoany__button a2a_button_email"></a>
                                        <a class="a2a_dd a2a_counter" href="https://www.addtoany.com/share_save"></a>
                                        </div>
                                        <!-- AddToAny END -->
                                    </div>

                                    {# <!-- AddToAny Sidebar -->
                                    {% if not mobile %}
                                        <div class="example_parent_element" style="margin:0 auto; width:900px;">
                                            <div class="a2a_kit a2a_kit_size_32 a2a_floating_style a2a_vertical_style" style="margin-left:-100px; top:150px;">
                                                <a class="a2a_button_facebook"></a>
                                                <a class="a2a_button_twitter"></a>
                                                <a class="a2a_button_pinterest"></a>
                                                <a class="a2a_button_whatsapp"></a>
                                                <a class="a2a_button_email"></a>
                                                <a class="a2a_dd a2a_counter" href="https://www.addtoany.com/share"></a>
                                            </div>
                                        </div>
                                    {% endif %} #}
                                {% endif %}

                                {% block page_content %}{% endblock %}

                                {% if show_ads and resp_rect %}
                                    <!-- (Responsive) Rectangle Ad -->
                                    <div class="adsense" style="280px">
                                        <ins class="adsbygoogle"
                                             style="display:block;margin:1.5em 0"
                                             data-ad-client="ca-pub-1461238060884369"
                                             data-ad-slot="{{ ad_id['resp_rect'] }}"
                                             data-ad-format="rectangle"></ins>
                                    </div>
                                    {# <script>
                                    (adsbygoogle = window.adsbygoogle || []).push({});
                                    </script> #}
                                {% endif %}

                                {% if show_ads and matched_content|default(1) %}
                                    <!-- PC (Responsive/Rectangle) Matched Content -->
                                    <div class="adsense">
                                        <ins class="adsbygoogle"
                                             style="display:block"
                                             data-ad-client="ca-pub-1461238060884369"
                                             data-ad-slot="7894600465"
                                             data-ad-format="autorelaxed"></ins>
                                    </div>
                                    {# <script>
                                    (adsbygoogle = window.adsbygoogle || []).push({});
                                    </script> #}
                                {% endif %}

                                {% block comments %}
                                    <div id="comments-button" class="button button--active">{{ br_view_comments|default('View Comments') }}</div>
                                    <div id="comments-box">
                                        <div id="fastcomments-widget"></div>
                                        {# <div class="disqus-placeholder">Loading comments...</div>
                                        <div class="disqus"></div> #}
                                    </div>
                                    {% if subscribe_data %}
                                        <a href="{{ subscribe_data['url'] }}" target="_blank" rel="nofollow"><div class="button button--subscribe button--active">Subscribe for Email Updates</div></a>
                                    {% endif %}
                                {% endblock %}

                                {% block b_real_time_ad %}{% endblock %}
                                {% if show_ads %}
                                    {% block ads_after_comments %}{% endblock %}
                                {% endif %}
                            </div>
                        </div>

                        <!-- side bar -->
                        {% block resp_vert %}
                            <div class="side-bar">

                                {% block navbar %}
                                    <div class="navbar-container shadow">
                                        <div class="button button--navbar" id="navbar-button">Site Navigation<span class="dropdown-symbol dropdown-symbol--dark">&#9660;</span></div>
                                        {% include 'navbar.twig' %}
                                    </div>
                                {% endblock %}

                                {% if subscribe_data %}
                                    <a href="https://matheasy.substack.com/" target="_blank" rel="nofollow"><div class="button button--subscribe button--active">Subscribe for Email Updates</div></a>
                                {% endif %}

                                {% block vertical_side_ad %}
                                    {% if show_ads %}
                                        <!-- (Responsive) Vertical -->
                                        <div class="adsense" style="height:600px">
                                            <ins class="adsbygoogle"
                                                 style="display:block;margin-bottom:1em;"
                                                 data-ad-client="ca-pub-1461238060884369"
                                                 data-ad-slot="{{ ad_id['resp_vert'] }}"
                                                 data-ad-format="vertical"></ins>
                                        </div>
                                        {# <script>
                                        (adsbygoogle = window.adsbygoogle || []).push({});
                                        </script> #}
                                    {% endif %}
                                {% endblock %}



                                {% if show_articles %}
                                    {% for item in articles %}
                                        <div class="latest-article"><a href="{{ item.url }}" target="_blank">
                                            <p class="big-text latest-article__tag">{{ item.tag_line }}</p>
                                            <img class="latest-article__logo lazyload" data-src="{{ item.img_url }}" alt="{{ item.img_alt }}" width="100%" height="auto">
                                            <p class="thin-font latest-article__title italic">{{ item.title }}</p></a>
                                        </div>
                                    {% endfor %}
                                {% endif %}

                            </div>
                        {% endblock %}
                        {% if show_ads %}
                            <!-- (Responsive) Horizontal -->
                            <div class="adsense" style="height:280px">
                                <ins class="adsbygoogle"
                                 style="display:block;margin:0.8em -1em 0 -1em"
                                 data-ad-client="ca-pub-1461238060884369"
                                 data-ad-slot="2696433413"
                                 data-ad-format="auto"
                                 data-full-width-responsive="true"></ins>
                            </div>
                            {# <script>
                            (adsbygoogle = window.adsbygoogle || []).push({});
                            </script> #}
                        {% endif %}
                    {% endblock %}
                </div>
                {% include 'footer.twig' %}
                {% block footer_ad %}{% endblock %}
            {% endblock %}
        </div>

        <script src="//ajax.googleapis.com/ajax/libs/jquery/1.11.3/jquery.min.js"></script>
        <script>
        var MES_Vars = {
            mobile: {% if mobile %}true{% else %}false{% endif %},
            hide_search: {% if hide_search %}true{% else %}false{% endif %},
            current_tab: {{ current_tab | default('1') - 1}}
        }
        {% block extra_js %}{% endblock %}
        </script>

        {% block javascripts %}
            {% if url|split('/')|last != 'contact' %}
                {# <script type="text/javascript">
                    var disqusOptions = {
                      scriptUrl: '//{{ disqus_url }}.disqus.com/embed.js',
                      laziness: 0,
                      throttle: 250,
                      disqusConfig: function()
                      {
                        this.page.url = '{{ url }}';  // Replace PAGE_URL with your page's canonical URL variable
                        this.page.identifier = '{{ url }}'; // Replace PAGE_IDENTIFIER with your page's unique identifier variable
                        this.callbacks.onReady = [function()
                        {
                            $( '.disqus-placeholder' ).addClass('hide');
                        }];
                      }
                    };
                </script> #}
                <script src="https://cdn.fastcomments.com/js/embed.min.js"></script>
                <script>
                    window.FastCommentsUI(document.getElementById('fastcomments-widget'), {
                        tenantId: '1RGmGBEjdU'
                    });
                </script>
            {% endif %}
            {% if localhost %}
                {% if local_root == "home_page" %}
                    <script src="../main_js/lazysizes.min.js?v=1.0.2" async></script>
                    {% if show_ads %}<script src="../main_js/jquery.adsenseloader.js?v=1.0.3" async></script>{% endif %}
                    {% if url|split('/')|last != 'contact' %}<script src="../main_js/jquery.disqusloader.js?v=1.0.3" async></script>{% endif %}
                {% else %}
                    <script src="../../main_js/lazysizes.min.js?v=1.0.3" async></script>
                    {% if show_ads %}<script src="../../main_js/jquery.adsenseloader.js?v=1.0.3" async></script>{% endif %}
                    {% if url|split('/')|last != 'contact' %}<script src="../../main_js/jquery.disqusloader.js?v=1.0.3" async></script>{% endif %}
                {% endif %}
            {% else %}
                <script src="https://mes.fm/main_js/lazysizes.min.js?v=1.0.3" async></script>
                {% if show_ads %}<script src="https://mes.fm/main_js/jquery.adsenseloader.js?v=1.0.3" async></script>{% endif %}
                {% if url|split('/')|last != 'contact' %}<script src="https://mes.fm/main_js/jquery.disqusloader.min.js?v=1.0.3" async></script>{% endif %}
            {% endif %}
        {% endblock %}

        {# {% if show_ads %}
            <script data-ad-client="ca-pub-1461238060884369" async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js"></script>
            <script type="text/javascript">$(".adsbygoogle").each(function () { (adsbygoogle = window.adsbygoogle || []).push({}); });</script>
        {% endif %} #}
        
        {% if localhost %}
            {% if local_root == "home_page" %}
                <script src="../main_js/main.js"></script>
            {% else %}
                <script src="../../main_js/main.js"></script>
            {% endif %}
        {% else %}
            <script src="https://mes.fm/main_js/main.js"></script>
        {% endif %}
    </body>
</html>
