{% extends base %}

{% block javascripts %}
	{{ parent() }}
	<script>$.getScript("{{ root_domain }}js/calculator.js");</script>
	<script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/js/bootstrap.min.js" integrity="sha384-Tc5IQib027qvyjSMfHjOMaLkfuWVxZxUPnCJA7l2mCWNIpG9mGCD8wGNIcPD7Txa" crossorigin="anonymous"></script>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-select/1.12.3/js/bootstrap-select.min.js"></script>
{% endblock %}

{% block bootstrap %}
	<link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css" integrity="sha384-BVYiiSIFeK1dGmJRAkycuHAHRg32OmUcww7on3RYdg4Va+PmSTsz/K68vbdEjh4u" crossorigin="anonymous">
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-select/1.12.3/css/bootstrap-select.min.css">
{% endblock %}

{% block extra_styles %}
	<style>
	.text-input {width:100%;max-width:1028px;min-height:20em;padding:1em; font-size: 16px;display: inline-block;-webkit-box-sizing: border-box;-moz-box-sizing: border-box;box-sizing: border-box;}
	.scanner {padding:1em; font-size: 16px;display: inline-block;text-align: left;white-space: pre-wrap;line-height:1.5;margin-bottom:1em;color;}
	.scanner span {color:#777777;} 
	.result {font-size: 48px; margin:0 auto;}
	.yellowBG {background-color: yellow;}
	.hide {display:none;}
	.basic-table--left {margin:0;}
	.basic-table td {text-align: left; vertical-align: middle;}
	.basic-table td:last-child {background-color: #eeeeee}
	.settings__input {border:1px solid #ccc;width:7em;border-radius:5px;background-color:#fff;height:2em;text-align: center;font-size: 1.1em;}
	.result-wrapper-outer {width:100%;height:20em;text-align: center; display: table;background-color: #eef0ff;margin:1em 0;}
	.result-wrapper-inner {display: table-cell;vertical-align: middle}
	.buttons-container {margin:1em 0;}
	.btn {margin-right:0.5em;}
	.btn:focus,.btn:active {outline:none !important;}
	.grey-bg {background-color: #e6e6e6}
	a,a:hover {text-decoration: none !important;color:white;}
	a.active-tab:hover {color:#222222;}
	.navbar {border:none;}
	#settingsTable .selected {background-color: white;}
	#settingsTable .btn {font-size:16px;}
	#fontSize {font-size:16px;}

	{% if not mobile %}
		#playSpeed::after {content:" Play";}
		#pauseSpeed::after {content:" Pause";}
		#stopSpeed::after {content:" Stop";}
		#settingsButton::after {content:" Settings";}
	{% endif %}
	</style>
{% endblock %}

{% block page_content %}
	<div id="main-content">
		<div class="buttons-container">
			<button id="playSpeed" class="btn btn-default btn-lg"><span class="glyphicon glyphicon-play" aria-hidden="true"></span></button>
			<button id="pauseSpeed" class="btn btn-default btn-lg hide"><span class="glyphicon glyphicon-pause" aria-hidden="true"></span></button>
			<button id="stopSpeed" class="btn btn-default btn-lg"><span class="glyphicon glyphicon-stop" aria-hidden="true"></span></button>
			<button id="settingsButton" class="btn btn-default btn-lg"><span class="glyphicon glyphicon-cog" aria-hidden="true"></span></button>
		</div>
		
		<table id="settingsTable" class="basic-table basic-table--full hide">
			<tr><td>Words Per Minute</td><td><input id="speed" class="settings__input" type="number" autocomplete="off" min="1" value="300" placeholder="eg 300"></td></tr>
			<tr><td>Font Size (px)</td><td>
				<select id="fontSize" class="selectpicker" data-width="123px">
					<option>8</option>
					<option>12</option>
					<option>16</option>
					<option>32</option>
					<option selected>48</option>
					{% if not mobile %}
						<option>76</option>
						<option>100</option>
						<option>120</option>
					{% endif %}
				</select></td></tr>
			<tr><td>Font Color</td><td><input id="font-color" class="settings__input" type="color" autocomplete="off" value="#333333"></td></tr>
			<tr><td>Background Color</td><td><input id="background-color" class="settings__input" type="color" autocomplete="off" value="#eef0ff"></td></tr>
			<tr><td>Number of Words</td><td>
				<select id="word-count" class="selectpicker" data-width="123px">
					<option selected>1</option>
					<option>2</option>
					<option>3</option>
					<option>4</option>
					<option>5</option>
					<option>6</option>
					<option>7</option>
					<option>8</option>
					<option>9</option>
					<option>10</option>
				</select>
			</td></tr>
		</table>

		<div id="result-container" class="result-wrapper-outer">
			<div class="result-wrapper-inner">
				<p id="result" class="result">Press Play!</p>
			</div>
		</div>

		<p id="scanner" class="scanner">All you have to do is copy and paste text into the text box and then press the "Play" button to start speed reading! You can adjust the settings of the Speed Reader by clicking the "Settings" button! Tap on any word in the text box below to start the Speed Reader at that position!</p>

		<textarea id="text-input" class="text-input" placeholder="Type anything..." autocomplete="off">All you have to do is copy and paste text into the text box and then press the "Play" button to start speed reading! You can adjust the settings of the Speed Reader by clicking the "Settings" button! Tap on any word in the text box below to start the Speed Reader at that position!</textarea>
	</div>
{% endblock %}