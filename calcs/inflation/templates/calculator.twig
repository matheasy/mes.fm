{% extends base %}

{% block javascripts %}
	{{ parent() }}
	<script>$.getScript("{{ root_domain }}js/calculator.js?v=1.8");</script>
	<script type="text/javascript" src="https://www.google.com/jsapi"></script>
	<script type="text/javascript">
	google.load("visualization", "1", {packages:["corechart"]});
	//google.setOnLoadCallback(drawChart);
	</script>
{% endblock %}

{% block extra_styles %}
	<style>
	.calculator-header {font-size: 1.1em;margin-bottom:1em;}
	#main-content .custom-input, #main-content select {height:1.8em;width:9em;font-size: 1em;text-align: center;}
	#main-content-container {display:table;table-layout: fixed;width:100%;}
	#left-side-container {display:table-cell;border-right: 0.15em solid #e1e1e1;width:45%;}
	#left-side-container div:last-child {margin-bottom:0.5em;}
	#left-side-container input {margin-left:0.3em;}
	#left-side-container input {margin-top: 0.5em;}
	#left-side-container select:not(:first-child) {margin-top: 0.5em;}
	#left-side-container span {display: inline-block;width:8.5em;font-size: 1em;font-weight: 400;}
	#right-side-container {display: table-cell;padding-left:2em;}
	.result-text {color:black;margin-top:0.8em;line-height: 1.3;font-style: italic;font-weight: 400;}
	.result-text span {font-weight: 700;}
	.active-button {background-color:#f0572e;color:white;}
	.graph-container {text-align: center;display:block;}
	.inflation-button, .cpi-button, .dollar-button {display:inline-block;width:13em;cursor:pointer;}
	.inflation-button {margin-right:0.6em;}
	.cpi-button {margin-right:0.6em;}
	#cpi-graph,#dollar-graph {display: none;}

	{% if mobile %}
		#left-side-container {display:block;border-right: 0;width:100%;}
		#left-side-container select {margin-bottom: 1em;}
		#left-side-container #custom-input-input {margin-left:0;}
		#right-side-container {display: block; padding-left: 0; margin-top:0.5em; margin-bottom:0.5em;}
		.inflation-button, .cpi-button, .dollar-button, .graph-data-button {display: block; width:auto;}
		.inflation-button, .cpi-button {margin-right: 0;}
		.dollar-button {margin-bottom:1em;}
		.basic-table {font-size: 0.85em;}
	{% endif %}
	</style>
{% endblock %}

{% block page_content %}
<div id="main-content">
	<div id="share-calc-button" class="button button--share-calc">Share Results</div>
	<div id="share-calc-url-container" class="share-calc-url-container hide">
		<span class="right-arrow">&#9654;</span>
		<input id="url-to-share" class="share-calc-url">
		<img src="//mes.fm/main_img/scissors-icon.png" height="32" width="19" id="copy-link-button" class="scissors-icon">
	</div>
	<div id="main-content-container">	
		<div id="left-side-container">
			<div>
				<span>Data Source</span>
				<select id="data-source-select">
					<option value="FRED">FRED</option>
					<option value="StatCan">StatCan</option>
					<option value="UK ONS">UK ONS</option>
					<option value="World Bank" selected>World Bank</option>
				</select>
			</div>
			<div>
				<span>Country</span><!--<input id="country-input" placeholder="eg Canada" type="text">-->
				<select id = "country-select">
					{% for item in countries %}
						{% if item.country == 'United States' %}
							<option value="{{ item.country }}" selected>{{ item.country }}</option>
						{% else %}
		                	<option value="{{ item.country }}">{{ item.country }}</option>
		                {% endif %}
		            {% endfor %}
	            </select>
			</div>
			<div>
				<span>Index Year</span><!--<input id="index-year-input" placeholder = "eg 1990" maxlength="4" type="text">-->
				<select id="index-year-select">
					<option value="115.1573032">2018</option>
				</select>
			</div>
			<div>
				<span>Comparison Year</span>
				<select id="comparison-year-select">
					<option value="115.1573032">2018</option>
				</select>
			</div>
			<div>
				<span>Custom Input ($)</span><input class="custom-input" id="custom-input-input" value = "1.00" placeholder = "eg 3.50" type="number" autocomplete="off">
			</div>
		</div>

		<div id="right-side-container">
			<p id="result-1" class="result-text">Please enter all of the fields to the left.</p>
			<p id="result-2" class="result-text"></p>
			<p id="result-3" class="result-text"></p>
		</div>
	</div>

	{% if mobile %}
		<div class="graph-container">
			<div class="inflation-button button active-button">Inflation Rate Graph</div>
			<div id="inflation-graph"></div>
			<div class="cpi-button button">CPI Graph</div>
			<div id="cpi-graph"></div>
			<div class="dollar-button button">Dollar Worth Graph</div>
			<div id="dollar-graph"></div>
		</div>
	{% else %}
		<div class="graph-container">
			<div class="inflation-button button active-button">Inflation Rate Graph</div>
			<div class="cpi-button button">CPI Graph</div>
			<div class="dollar-button button">Dollar Worth Graph</div>
			<div id="inflation-graph"></div>
			<div id="cpi-graph"></div>
			<div id="dollar-graph"></div>
		</div>
	{% endif %}

	<div class="button graph-data-button hide-div-button" id="graph-table-button">Graph Data Table</div>
	<div class="hide">
		<p id="data-table-title" class="header2">*Worth of $1.00 each Year vs. $1.00 in Index Year (2014)</p>
		<table id="graph-table" class="basic-table basic-table--full"></table>
	</div>

</div>
{% endblock %}