{% extends base %}

{% block javascripts %}
	{{ parent() }}
	<script>
	var pageLink = $(".page-link");
	pageLink.each(function() {
		if($(this).html() == {{ page }}) {
			$(this).addClass("active-page");
			return false;
		}
	});
	</script>
{% endblock %}

{% block extra_styles %}
	<style>
	.memes {margin:0 auto;}
	.memes__row {border-bottom: 1em solid transparent;}
	.memes__img-container:not(:last-child) {border-right:1em solid transparent;}
	.memes__link {display: block;}
	.memes__img {height:10.0625em;width:10.0625em;display: block;border:0.15em solid #d4d4d4;box-sizing: border-box;-moz-box-sizing: border-box;-webkit-box-sizing: border-box;}
	.btn-container {width:100%; display: table;margin-bottom: 2em;table-layout: fixed;}
	.page-numbers {display: table-cell;text-align: center;vertical-align: middle;}
	.btn-link {display: table-cell;}
	.page-link {font-size: 1.2em;padding:0 0.4em;}
	.active-page {font-weight: 700;color:{{ dark_color }};cursor: default;}
	{% if mobile %}
	.memes__row {border-bottom: 0.5em solid transparent;}
	.memes__img-container:not(:last-child) {border-right:0.5em solid transparent;}
	.memes__img {width: 100%;height:auto;min-width:8.5em;min-height: 8.5em;}
	.btn-container {margin-top:0.5em;}
	.page-numbers {width:20%;}
	.btn-link {text-align: center;width:30%;}
	{% else %}
	.memes__img:hover {border-color: {{ dark_color }};}
	.page-link:hover:not(.active-page) {text-decoration: underline;}
	.btn-link:hover {background-color: {{ dark_color }};color:white;}
	{% endif %}
	</style>
{% endblock %}

