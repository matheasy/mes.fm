                <a href="https://matheasy.substack.com/" target="_blank" rel="nofollow"><div class="button button--subscribe button--active">Subscribe for Email Updates</div></a>
            {% endif %}

		</div>
	{% endif %}
{% endblock %}

{% block alt_big_mobile_ad_1 %}{% endblock %}

{% block alt_big_mobile_ad_3 %}{% endblock %}

{% block page_content %}
	<div id="main-content">
		<table class="memes">
			<tr class="memes__row">
			{% for item in data %}
				<td class="memes__img-container"><a class="memes__link" href="{{ root_domain }}{{ memes_dir | default('memes')}}/{{ item.urlname }}" title="{{ item.title }}">
					{% if mobile %}
						<img height="161" width="161" class="memes__img" src="https://{{ url_short }}/img/memes-thumbnail/{{ item.thumbnailurl }}" alt="{{ item.title }}">
					{% else %}
						<img height="161" width="161" class="memes__img" src="https://{{ url_short }}/img/memes-thumbnail/{{ item.thumbnailurl2 }}" alt="{{ item.title }}">
					{% endif %}
				</a></td>
				{% if loop.index % items_per_row == 0 and not loop.last %}
					</tr><tr class="memes__row">
				{% endif %}
			{% endfor %}
			</tr>
		</table>
		<div class="btn-container">
			{% if page != 1 %}<a class="button btn-link" href="{{root__domain}}{{ memes_dir | default('memes')}}/{{ page - 1 }}">&#9668;&nbsp;&nbsp;Previous</a>{% endif %}
			{% if mobile %}
				<div class="page-numbers">Page {{ page }}</div>
			{% else %}
				<div class="page-numbers">
					{% if page < 4 or not data %}
						{% if max_page > 4 %}
							{% for i in range(1 , 5) %}
								<a class="page-link" href="{{root__domain}}{{ memes_dir | default('memes')}}/{{ i }}">{{ i }}</a>
							{% endfor %}
						{% else %}
							{% for i in range(1 , max_page) %}
								<a class="page-link" href="{{root__domain}}{{ memes_dir | default('memes')}}/{{ i }}">{{ i }}</a>
							{% endfor %}
						{% endif %}
					{% elseif page > 3 and page < (max_page - 1) %}
						{% for i in range((page-2) , (page+2)) %}
							<a class="page-link" href="{{root__domain}}{{ memes_dir | default('memes')}}/{{ i }}">{{ i }}</a>
						{% endfor %}
					{% else %}
						{% if max_page > 4 %}
							{% for i in range((max_page-4) , max_page) %}
								<a class="page-link" href="{{root__domain}}{{ memes_dir | default('memes')}}/{{ i }}">{{ i }}</a>
							{% endfor %}
						{% else %}
							{% for i in range(1 , max_page) %}
								<a class="page-link" href="{{root__domain}}{{ memes_dir | default('memes')}}/{{ i }}">{{ i }}</a>
							{% endfor %}
						{% endif %}
					{% endif %}
				</div>
			{% endif %}
			{% if page != max_page %}<a class="button btn-link" href="{{root__domain}}{{ memes_dir | default('memes')}}/{{ page + 1 }}">Next&nbsp;&nbsp;&#9658;</a>{% endif %}
		</div>

		{% if mobile %}
			<!-- Insticator API Fire Widget --><div id="insticator-container"><div id="div-insticator-ad-1"></div><div id="insticator-embed"></div><div id="div-insticator-ad-2"></div><script data-cfasync='false' type="text/javascript">/*<![CDATA[*/Insticator.ad.loadAd("div-insticator-ad-1");Insticator.ad.loadAd("div-insticator-ad-2");Insticator.load("em",{id : "0235ffb3-a6df-4a1d-b2ef-6e3c668a10bd"})/*]]>*/</script></div><!-- End Insticator API Fire Widget -->                                       
		{% endif %}

		{% if show_youtube_ads and not mobile %}{% endif %}	

	</div>
{% endblock %}