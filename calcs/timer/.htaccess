AcceptPathInfo Off
Options +FollowSymLinks -MultiViews

RewriteEngine on

# RewriteBase /MattAndMike/MathEasySolutions/twig_templates/math_easy_solutions/timer/
RewriteBase /

# remove www and redirect to https
RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# redirect non-www http to https
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Remove ?p= from memes pages
RewriteRule ^inspirational-quotes/([0-9]+)/?$ inspirational-quotes/?p=$1 [L]

# Reroute to main controller
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([^\.]+)/?$ index.php?uri=$1 [QSA,L]